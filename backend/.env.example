# Django
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (leave blank to use SQLite for local dev)
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=

# Redis (Channels layer)
REDIS_URL=redis://127.0.0.1:6379/0

# CORS / Frontend
FRONTEND_ORIGIN=http://localhost:5173

# SMS provider (e.g. Eskiz / Play Mobile). Leave blank in dev to print OTP to console.
SMS_PROVIDER=
SMS_API_KEY=
SMS_SENDER=

# Telegram bot (Mini App)
TELEGRAM_BOT_TOKEN=
# Public HTTPS URL of the frontend (Mini App) — used by the bot's web_app button.
# Local dev: expose the Vite server via ngrok/cloudflared and paste the URL here.
WEBAPP_URL=https://example.com

# OTP
OTP_TTL_SECONDS=300
OTP_DEV_PRINT=True
