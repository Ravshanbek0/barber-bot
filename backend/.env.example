# Django
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
# Cloud (Render/Railway) gives a single DATABASE_URL — set it and the discrete
# DB_* vars below are ignored. Leave DATABASE_URL blank to use SQLite locally.
DATABASE_URL=
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=

# Redis (Channels layer)
REDIS_URL=redis://127.0.0.1:6379/0

# CORS / Frontend (comma-separated). In production include the Vercel origin.
FRONTEND_ORIGIN=http://localhost:5173
# CSRF (production): the backend's own https origin(s), comma-separated.
CSRF_TRUSTED_ORIGINS=

# SMS provider (e.g. Eskiz / Play Mobile). Leave blank in dev to print OTP to console.
SMS_PROVIDER=
SMS_API_KEY=
SMS_SENDER=

# Telegram bot (Mini App)
TELEGRAM_BOT_TOKEN=
# Public HTTPS URL of the frontend (Mini App) — used by the bot's web_app button.
# Local dev: expose the Vite server via ngrok/cloudflared and paste the URL here.
WEBAPP_URL=https://example.com

# OTP
OTP_TTL_SECONDS=300
OTP_DEV_PRINT=True
